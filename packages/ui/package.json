{
  "name": "@yavuzmercan/ui",
  "version": "0.1.0",
  "description": "Theme-aware, i18n-ready React UI framework — 70+ components, 88+ icons, design tokens, Google Fonts loader. One install, everything included.",
  "keywords": [
    "react",
    "ui",
    "framework",
    "components",
    "icons",
    "design-system",
    "design-tokens",
    "theme",
    "i18n",
    "accessibility",
    "mercan"
  ],
  "license": "MIT",
  "homepage": "https://github.com/yavuzmercan/mercan-react-framework#readme",
  "bugs": {
    "url": "https://github.com/yavuzmercan/mercan-react-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yavuzmercan/mercan-react-framework.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./icons": "./src/icons/index.ts",
    "./components": "./src/components/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./icons": {
        "types": "./dist/icons.d.ts",
        "import": "./dist/icons.js",
        "require": "./dist/icons.cjs"
      },
      "./components": {
        "types": "./dist/components.d.ts",
        "import": "./dist/components.js",
        "require": "./dist/components.cjs"
      },
      "./styles.css": "./dist/styles.css"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
