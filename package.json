{
  "name": "mercan-react-framework",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/sample-web",
    "docs": "npm run dev --workspace apps/docs",
    "storybook": "npm run storybook --workspace packages/ui",
    "build-storybook": "npm run build-storybook --workspace packages/ui",
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build --workspace packages/ui",
    "test": "npm test --workspace packages/ui",
    "typecheck": "tsc -b",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
