{
  "name": "mercan-react-framework",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/sample-web",
    "docs": "npm run dev --workspace apps/docs",
    "build": "npm run build --workspaces --if-present",
    "build:packages": "npm run build --workspace packages/ui",
    "test": "npm test --workspace packages/ui",
    "typecheck": "tsc -b",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:packages && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  }
}
